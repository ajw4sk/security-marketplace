.DS_Store
node_modules/
*.log

# Plugin runtime state — created by the doctor at install time
sec-policy-analyzer-node/scripts/.state/

# Scratch / work-in-progress catalog snapshots and intermediate JSON
tmp/

# Local test fixtures + outputs (not part of the shipped plugin)
tests/

# Scaffolded user-side parsing workspace (created by run.sh scaffold).
# End-user projects may want to commit this; in this plugin repo it's noise
# from local test runs.
parsing-output/

# Claude Code project settings — never commit any of these.
# Settings live in .claude/settings.local.json (local-only) by convention; everything in this directory stays local.
.claude/

# Test outputs
*.csv
*_only.json
*_associated_controls.json
*_complete_associations.json
*.v3.json
mapping*.json
mapping_report.md
mapping_best_picks.csv
